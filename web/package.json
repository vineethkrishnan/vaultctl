{
  "name": "@vaultctl/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "api:fetch": "curl -s http://localhost:8080/swagger/doc.json -o ../docs/swagger.json",
    "api:generate": "orval --config orval.config.ts",
    "api:update": "npm run api:fetch && npm run api:generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hash-wasm": "^4.11.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.54.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "orval": "^8.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
