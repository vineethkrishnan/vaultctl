# vaultctl .env template — see prd.md §11.1
# Copy to .env and fill in every secret. The server REFUSES TO START in
# VAULTCTL_ENV=production if any secret below is missing (fail-closed, H5/H8/C3).
#
# Generate all secrets with:
#   openssl rand -base64 32   # 32-byte values
#   openssl rand -base64 64   # JWT secrets (recommended 64-byte)

# ===========================================================================
# Server
# ===========================================================================
VAULTCTL_PORT=8080
VAULTCTL_HOST=0.0.0.0
VAULTCTL_BASE_URL=https://vault.example.com
VAULTCTL_ENV=production                       # production | development

# ===========================================================================
# Database
# ===========================================================================
VAULTCTL_DB_HOST=vaultctl-db
VAULTCTL_DB_PORT=5432
VAULTCTL_DB_NAME=vaultctl
VAULTCTL_DB_USER=vaultctl
VAULTCTL_DB_PASSWORD=change-me
# [H12] default: require. 'disable' is permitted ONLY inside the Docker
# Compose loopback network (overridden in docker-compose.yml).
VAULTCTL_DB_SSL_MODE=require                  # require | verify-full | disable
# [H12] Required to opt-in to ssl_mode=disable in production. Set automatically
# by the bundled docker-compose where Postgres lives on a private bridge net.
# Leave unset (false) for any cross-host or untrusted-network deploy.
VAULTCTL_DB_SSL_INSECURE_OK=false

# ===========================================================================
# JWT signing keys — dual-key rotation (H8)
# ===========================================================================
VAULTCTL_JWT_SECRET_CURRENT=change-me-openssl-rand-base64-64
VAULTCTL_JWT_SECRET_NEXT=
VAULTCTL_JWT_KID_CURRENT=k1
VAULTCTL_JWT_ACCESS_TTL=15m
VAULTCTL_JWT_REFRESH_TTL=168h

# ===========================================================================
# Server-side data encryption key (H5) — encrypts totp_secret, password_hint
# MUST live in a DIFFERENT location from DB backups (PRD §17.4, M2).
# ===========================================================================
VAULTCTL_DATA_ENCRYPTION_KEY=change-me-openssl-rand-base64-32
VAULTCTL_DATA_ENCRYPTION_KEY_NEXT=

# ===========================================================================
# Server peppers (C3 / H7 / H2) — never rotated casually
# ===========================================================================
VAULTCTL_SERVER_PEPPER=change-me-openssl-rand-base64-32
VAULTCTL_ENUMERATION_PEPPER=change-me-openssl-rand-base64-32

# ===========================================================================
# Security
# ===========================================================================
# First-user bootstrap: when the users table is empty, the first registration
# is always allowed regardless of this setting and the user is promoted to
# owner. After that, the configured mode applies normally. Default 'invite'
# keeps the server locked down once the first owner exists.
VAULTCTL_REGISTRATION_MODE=invite             # open | invite | disabled
VAULTCTL_REQUIRE_2FA=false
VAULTCTL_MAX_LOGIN_ATTEMPTS=5
VAULTCTL_LOCKOUT_DURATION=15m
VAULTCTL_RATE_LIMIT_RPM=60
VAULTCTL_AUTH_RATE_LIMIT_PER_EMAIL=5
VAULTCTL_AUTH_RATE_LIMIT_WINDOW=15m
VAULTCTL_AUTH_GLOBAL_ALERT_THRESHOLD=1000
VAULTCTL_TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12
VAULTCTL_STEP_UP_MAX_AGE=5m
VAULTCTL_MIN_PASSWORD_LENGTH=10               # minimum master-password length

# ===========================================================================
# Retention
# ===========================================================================
VAULTCTL_TRASH_RETENTION_DAYS=30
VAULTCTL_BACKUP_RETENTION_DAYS=90

# ===========================================================================
# Attachments (encrypted files stored on the filesystem blob store)
# The bundled compose mounts the attachments-data volume here. Back this
# directory up alongside Postgres — losing one orphans the other.
# ===========================================================================
VAULTCTL_ATTACHMENTS_DIR=/data/attachments
VAULTCTL_ATTACHMENT_MAX_BYTES=26214400            # 25 MiB per file
VAULTCTL_ATTACHMENT_VAULT_QUOTA_BYTES=524288000   # 500 MiB per vault

# ===========================================================================
# Backup & Sync (per-user scheduled encrypted backups)
# Requires VAULTCTL_DATA_ENCRYPTION_KEY (artifacts + provider creds are sealed
# with it). Local, WebDAV and S3 need no server config — users supply their own
# credentials. Cloud OAuth providers activate only when their client ID/secret
# are set; register each app's redirect URI as
# ${VAULTCTL_BASE_URL}/api/v1/backup/oauth/<provider>/callback.
# ===========================================================================
VAULTCTL_BACKUP_SYNC_ENABLED=true
VAULTCTL_BACKUP_LOCAL_DIR=/data/backups
# VAULTCTL_BACKUP_GOOGLE_CLIENT_ID=
# VAULTCTL_BACKUP_GOOGLE_CLIENT_SECRET=
# VAULTCTL_BACKUP_DROPBOX_CLIENT_ID=
# VAULTCTL_BACKUP_DROPBOX_CLIENT_SECRET=
# VAULTCTL_BACKUP_ONEDRIVE_CLIENT_ID=
# VAULTCTL_BACKUP_ONEDRIVE_CLIENT_SECRET=

# ===========================================================================
# Logging (C4, M1)
# ===========================================================================
VAULTCTL_LOG_LEVEL=info                       # debug | info | warn | error
VAULTCTL_LOG_FORMAT=json                      # json | text
VAULTCTL_LOG_IP_PRECISION=coarse              # coarse | full | none
VAULTCTL_LOG_REDACT_FIELDS=authHash,password,refresh_token,api_key,totp,masterKey,stretchedKey
