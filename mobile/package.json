{
  "name": "vaultctl-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@vaultctl/shared/(.*)$": "<rootDir>/../web/src/shared/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|@expo|react-native|@react-native|expo-modules-core)/)"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-argon2": "^4.0.0",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-quick-base64": "^3.0.0",
    "react-native-quick-crypto": "^1.1.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.9",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.72.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "typescript": "^5.7.2"
  },
  "private": true
}
