{
  "name": "vaultctl-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@vaultctl/shared/(.*)$": "<rootDir>/../web/src/shared/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|@expo|react-native|@react-native|expo-modules-core)/)"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "expo": "~52.0.47",
    "expo-build-properties": "~0.13.2",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-file-system": "~18.0.10",
    "expo-linking": "~7.0.4",
    "expo-local-authentication": "~15.0.2",
    "expo-router": "~4.0.17",
    "expo-secure-store": "~14.0.1",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-argon2": "^4.0.0",
    "react-native-quick-crypto": "^0.7.6",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.9",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.72.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "typescript": "^5.7.2"
  },
  "private": true
}
